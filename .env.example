APP_NAME=RAG Agent Decision System
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=agent_chunks
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+psycopg://agent:agent@127.0.0.1:15432/agent?connect_timeout=2

LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
RERANK_PROVIDER=sentence-transformers
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_BATCH_SIZE=16
RETRIEVAL_CANDIDATE_MULTIPLIER=8
KNN_NUM_CANDIDATES_MULTIPLIER=20
DEPENDENCY_CHECK_TIMEOUT_SECONDS=2
REQUIRE_API_KEY=false
API_KEY=
MAX_QUESTION_LENGTH=2000
MAX_SESSION_ID_LENGTH=128
ALLOWED_TOOL_SCOPES=retrieval,memory,planning,mission
